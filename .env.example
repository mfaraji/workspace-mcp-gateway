# Postgres connection (SQLAlchemy psycopg3 driver).
# Local dev uses a dedicated role/db on the host Postgres:
DATABASE_URL=postgresql+psycopg://workspace_mcp:wmcp_local_dev_pw@127.0.0.1:5432/workspace_mcp

# Public base URL of the gateway. Used to derive the OAuth redirect URI:
#   {BASE_URL}/oauth/google/callback
BASE_URL=http://localhost:8000

# Google OAuth client (Web application) credentials.
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me

# Fernet key for encrypting provider tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace-me-with-a-fernet-key

# Shared secret proving a request comes from the trusted Open WebUI deployment.
# Open WebUI must send this as the X-Gateway-Auth header on every MCP request;
# the public reverse proxy strips that header so public callers can't present it.
# This is the gate for header-based identity. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GATEWAY_SHARED_SECRET=replace-me-with-a-shared-secret

# Trusted Open WebUI origin. Defense-in-depth only (no longer the trust gate);
# retained for optional logging. Set to the public URL of the gateway.
TRUSTED_OPEN_WEBUI_ORIGIN=http://localhost:8000

# Secret for signing session cookies and OAuth state tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-random-secret

# Local-dev only: when "true", plain identity headers are trusted regardless of
# origin so you can exercise the flow without a reverse proxy. NEVER set in prod.
DEV_TRUST_ALL_ORIGINS=false
